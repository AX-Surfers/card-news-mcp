{
  "name": "card-news-mcp",
  "version": "1.0.0",
  "description": "MCP server that renders Instagram-style square card news (720x720 PNG) from text + images, with themeable branding and pluggable storage.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "card-news-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "themes",
    "README.md",
    "README.ko.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test:render": "tsx src/test-render.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "card-news",
    "instagram",
    "image-generation",
    "playwright",
    "social-media"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "handlebars": "^4.7.8",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
