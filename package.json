{
  "name": "card-news-mcp",
  "version": "1.0.0",
  "description": "Claude Code plugin: renders Instagram-style 1080x1350 card news (PNG) from text + images, with themeable branding and pluggable storage.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "card-news-render": "dist/render-cli.js",
    "card-news-render-overlay": "dist/render-overlay-cli.js"
  },
  "files": [
    "dist",
    "themes",
    "scripts",
    "README.md",
    "README.ko.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/render-cli.ts",
    "render": "node dist/render-cli.js",
    "render:overlay": "node dist/render-overlay-cli.js",
    "typecheck": "tsc --noEmit",
    "test:render": "tsx src/test-render.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "card-news",
    "instagram",
    "playwright",
    "social-media"
  ],
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.8",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
