# --- Theme ---
THEME=default
# THEME_DIR=/absolute/path/to/custom-theme

# --- Storage ---
STORAGE_BACKEND=local
OUTPUT_DIR=./card-news-out

# --- Transport ---
MCP_TRANSPORT=stdio
# PORT=3000

# --- Supabase backend (only if STORAGE_BACKEND=supabase) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_BUCKET=card-images

# --- S3 / R2 backend (only if STORAGE_BACKEND=s3) ---
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
